<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
android:layout_marginHorizontal="3dp"    android:layout_width="60dp"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/graph_score_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="80점"
        android:textAppearance="@style/caption2_Semibold"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/graph_bar_view"
        app:layout_constraintStart_toStartOf="@id/graph_bar_view"
        app:layout_constraintEnd_toEndOf="@id/graph_bar_view"/>

    <View
        android:id="@+id/graph_bar_view"
        android:layout_width="38dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_graph"
        android:backgroundTint="@color/brand_200"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/graph_rank_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/graph_rank_tv"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_rank_circle"
        android:backgroundTint="@color/brand_200"
        android:gravity="center"
        android:text="A"
        android:textColor="@color/brand_800"
        android:layout_marginBottom="10dp"
        android:textAppearance="@style/caption1_Semibold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>