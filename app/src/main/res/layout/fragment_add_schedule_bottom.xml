<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingHorizontal="20dp"
    android:paddingBottom="20dp">

    <FrameLayout
        android:id="@+id/view_container"
        android:layout_width="46dp"
        android:layout_height="24dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <View
            android:id="@+id/handle_bar"
            android:layout_width="39dp"
            android:layout_height="2.6dp"
            android:background="@color/white"
            android:layout_marginStart="3.74dp"
            android:layout_marginTop="10.7dp"
            />
    </FrameLayout>

    <ImageView
        android:id="@+id/on_flow_iv"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_on_flow"
        android:layout_marginTop="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_container"/>

    <TextView
        android:id="@+id/schedule_title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="탐색할 집의 \n주소를 입력해주세요"
        android:layout_marginTop="30dp"
        android:textAppearance="@style/heading2_Semibold"
        app:layout_constraintTop_toBottomOf="@id/on_flow_iv"
        app:layout_constraintStart_toStartOf="parent"/>
    
    <ViewFlipper
        android:id="@+id/main_step_flipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:inAnimation="@anim/fade_in"
        android:outAnimation="@anim/fade_out"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/schedule_title_tv"
        app:layout_constraintBottom_toTopOf="@id/address_next_btn_mb"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_step_address"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <EditText
                android:id="@+id/schedule_input_et"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:background="@drawable/text_btn"
                android:hint="탐색 주거 도로명주소"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textColorHint="@color/gray_500"
                android:textAppearance="@style/body1_Regular"
                android:maxLines="1"
                android:inputType="text"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/date_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="@drawable/round_16dp_gray800"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/btn_prev_month"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/back"
                    android:padding="4dp"/>

                <TextView
                    android:id="@+id/tv_year_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025년 01월"
                    android:textColor="@color/white"
                    android:textAppearance="@style/body1_Semibold"
                    android:layout_marginHorizontal="40dp"/>

                <ImageView
                    android:id="@+id/btn_next_month"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/next"
                    android:padding="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:weightSum="7">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="일"
                    android:textAppearance="@style/body2_Median"
                    android:textColor="@color/error_600"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="월"
                    android:textAppearance="@style/body2_Median"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="화"
                    android:textAppearance="@style/body2_Median"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="수"
                    android:textAppearance="@style/body2_Median"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="목"
                    android:textAppearance="@style/body2_Median"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="금"
                    android:textAppearance="@style/body2_Median"
                    android:textColor="@color/white"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="토"
                    android:textAppearance="@style/body2_Median"
                    android:textColor="@color/brand_600"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/calendarRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:overScrollMode="never"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/time_picker_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/schedule_date_display_tv"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/text_btn"
                android:gravity="center_vertical"
                android:text="2026년 01월 01일 10시 00분"
                android:paddingHorizontal="16dp"
                android:textColor="@color/gray_500"
                android:textAppearance="@style/body1_Regular"
                android:layout_marginHorizontal="20dp"/>

            <FrameLayout
                android:id="@+id/picker_inner_frame"
                android:layout_width="200dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="33dp"
                    android:background="#55FFFFFF"
                    android:clickable="false"
                    android:focusable="false"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="66dp"
                    android:background="#55FFFFFF"
                    android:clickable="false"
                    android:focusable="false"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:weightSum="100">

                    <com.keder.zply.FixedRecyclerView
                        android:id="@+id/hourRecyclerView"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="35"
                        android:paddingVertical="33dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:scrollbars="none"/>

                    <TextView
                        android:id="@+id/time_colon"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text=":"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:includeFontPadding="false"/>

                    <com.keder.zply.FixedRecyclerView
                        android:id="@+id/minuteRecyclerView"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="35"
                        android:paddingVertical="33dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:scrollbars="none"/>

                    <com.keder.zply.FixedRecyclerView
                        android:id="@+id/ampmRecyclerView"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="30"
                        android:paddingVertical="33dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:scrollbars="none"/>

                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </ViewFlipper>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/address_next_btn_mb"
        style="@style/btn_L"
        android:backgroundTint="@color/brand_700"
        android:text="입력하기"
        android:textColor="@color/white"
        android:layout_marginBottom="10dp"
        android:textAppearance="@style/body1_Semibold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
</androidx.constraintlayout.widget.ConstraintLayout>