<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/ing_back_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/back"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


    <include
        android:id="@+id/ing_progress_layout"
        layout="@layout/layout_step_progress_ing"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="34dp"
        android:layout_marginStart="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ing_back_iv"/>

    <LinearLayout
        android:id="@+id/ing_btn_ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:weightSum="2"
        android:layout_marginTop="34dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ing_progress_layout">
        <TextView
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_6dp_btn"
            android:backgroundTint="@color/brand_600"
            android:text="측정하기"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:layout_weight="1"
            android:textAppearance="@style/caption1_Semibold"
            android:textColor="@color/white"/>

        <TextView
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_6dp_btn"
            android:text="기존 정보 보기"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/caption1_Semibold"
            android:textColor="@color/white"/>
    </LinearLayout>

    <View
        android:id="@+id/btn_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/ing_btn_ll"
        android:backgroundTint="@color/gray_700"
        android:background="@color/gray_700"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/measure_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="34dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_divider">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">
            <TextView
                android:id="@+id/text_vp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘 탐색하는 집의 \n정보를 측정할게요"
                android:textAppearance="@style/heading2_Semibold"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>


            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/house_vp"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="20dp"
                android:clipToPadding="false"
                app:layout_constraintTop_toBottomOf="@id/text_vp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/steps_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:padding="4dp"
                app:layout_constraintTop_toBottomOf="@id/house_vp">

                <TextView
                    android:id="@+id/step1_num"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/gray_circle_badge"
                    android:gravity="center"
                    android:text="1"
                    android:textAppearance="@style/caption2_Semibold"
                    android:textColor="@color/gray_800"
                    android:backgroundTint="@color/gray_500"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/step1_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="채광을 측정해요"
                    android:textAppearance="@style/body1_Semibold"
                    android:textColor="@color/gray_500"
                    app:layout_constraintBottom_toBottomOf="@id/step1_num"
                    app:layout_constraintStart_toEndOf="@id/step1_num"
                    app:layout_constraintTop_toTopOf="@id/step1_num" />

                <TextView
                    android:id="@+id/step1_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="해당 정보는 ZIPLY가 자동 측정했어요"
                    android:textAppearance="@style/caption1_Median"
                    android:textColor="@color/gray_500"
                    app:layout_constraintStart_toStartOf="@id/step1_title"
                    app:layout_constraintTop_toBottomOf="@id/step1_title" />

                <TextView
                    android:id="@+id/step1_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_6dp_btn"
                    android:backgroundTint="@color/gray_700"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="측정완료"
                    android:textAppearance="@style/caption1_Semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/step1_title"
                    app:layout_constraintBottom_toBottomOf="@id/step1_desc"/>

                <View
                    android:id="@+id/line1"
                    android:layout_width="2dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_6dp_btn"
                    android:backgroundTint="@color/gray_600"
                    app:layout_constraintEnd_toEndOf="@id/step1_num"
                    app:layout_constraintStart_toStartOf="@id/step1_num"
                    app:layout_constraintTop_toBottomOf="@id/step1_num" />

                <TextView
                    android:id="@+id/step2_num"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/gray_circle_badge"
                    android:gravity="center"
                    android:text="2"
                    android:textAppearance="@style/caption2_Semibold"
                    android:textColor="@color/gray_800"
                    android:layout_marginTop="26dp"
                    android:backgroundTint="@color/white"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/line1" />

                <TextView
                    android:id="@+id/step2_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="방향을 측정해요"
                    android:textAppearance="@style/body1_Semibold"
                    android:textColor="@color/white"
                    app:layout_constraintBottom_toBottomOf="@id/step2_num"
                    app:layout_constraintStart_toEndOf="@id/step2_num"
                    app:layout_constraintTop_toTopOf="@id/step2_num" />

                <TextView
                    android:id="@+id/step2_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="온도, 채광 등 추가 정보를 알 수 있어요"
                    android:textAppearance="@style/caption1_Median"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toStartOf="@id/step2_title"
                    app:layout_constraintTop_toBottomOf="@id/step2_title" />

                <TextView
                    android:id="@+id/step2_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_6dp_btn"
                    android:backgroundTint="@color/brand_700"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="측정하기"
                    android:textAppearance="@style/caption1_Semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/step2_title"
                    app:layout_constraintBottom_toBottomOf="@id/step2_desc"/>

                <View
                    android:id="@+id/line2"
                    android:layout_width="2dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_6dp_btn"
                    android:backgroundTint="@color/white"
                    app:layout_constraintEnd_toEndOf="@id/step2_num"
                    app:layout_constraintStart_toStartOf="@id/step2_num"
                    app:layout_constraintTop_toBottomOf="@id/step2_num" />

                <TextView
                    android:id="@+id/step3_num"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/gray_circle_badge"
                    android:gravity="center"
                    android:text="+"
                    android:textAppearance="@style/caption2_Semibold"
                    android:textColor="@color/gray_800"
                    android:layout_marginTop="26dp"
                    android:backgroundTint="@color/white"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/line2" />

                <TextView
                    android:id="@+id/step3_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="사진을 촬영해요"
                    android:textAppearance="@style/body1_Semibold"
                    android:textColor="@color/white"
                    app:layout_constraintBottom_toBottomOf="@id/step3_num"
                    app:layout_constraintStart_toEndOf="@id/step3_num"
                    app:layout_constraintTop_toTopOf="@id/step3_num" />

                <TextView
                    android:id="@+id/step3_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="집의 상태를 시각적으로 기록할 수 있어요"
                    android:textAppearance="@style/caption1_Median"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toStartOf="@id/step3_title"
                    app:layout_constraintTop_toBottomOf="@id/step3_title" />

                <TextView
                    android:id="@+id/step3_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_6dp_btn"
                    android:backgroundTint="@color/brand_700"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="촬영하기"
                    android:textAppearance="@style/caption1_Semibold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/step3_title"
                    app:layout_constraintBottom_toBottomOf="@id/step3_desc"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/photo_rv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/step3_title"
                    app:layout_constraintTop_toBottomOf="@id/step3_desc" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/existing_info_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ing_btn_ll"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loading_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/brand_100"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>