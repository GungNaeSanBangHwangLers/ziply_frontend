<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_marginTop="40dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <TextView
        android:id="@+id/after_light_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="채광은 {Char}가 /n가장 좋네요!"
        android:textAppearance="@style/body1_Semibold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/after_light_des_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="당일 조도센서로 측정한 값을 점수로 산출했어요."
        android:textAppearance="@style/caption1_Median"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="@id/after_light_tv"
        app:layout_constraintTop_toBottomOf="@id/after_light_tv"/>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/graph_container"
        android:layout_width="320dp"
        android:layout_height="197dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="30dp"
        android:paddingBottom="20dp"
        android:background="@drawable/gray_bg16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/after_light_des_tv">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/before_graph_rv"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:paddingTop="20dp"
            android:overScrollMode="never"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constrainedWidth="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:listitem="@layout/item_graph_bar"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/empty_state_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="측정된 데이터가 없어 \n결과를 준비하지 못했어요"
        android:gravity="center"
        android:textColor="@color/gray_400"
        android:textAppearance="@style/body2_Regular"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>