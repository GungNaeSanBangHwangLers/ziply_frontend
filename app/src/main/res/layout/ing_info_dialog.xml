<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/gray_bg20"
    android:padding="20dp">


    <TextView
        android:id="@+id/alert_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="이렇게 측정해주세요"
        android:textAppearance="@style/heading2_Semibold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/alert_des_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="사진과 같이 휴대폰을 \n창문을 향해 맞춘 후 측정해주세요."
        android:textAppearance="@style/body2_Median"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/alert_tv"/>

    <ImageView
        android:id="@+id/alert_img"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_direction_info"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/alert_des_tv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/btns_ll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/alert_img">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/alert_cancel_btn"
            style="@style/btn_MS"
            android:textColor="@color/white"
            android:backgroundTint="@color/gray_700"
            android:text="취소" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/alert_ok_btn"
            style="@style/btn_MS"
            android:backgroundTint="@color/brand_700"
            android:layout_marginStart="8dp"
            android:textColor="@color/white"
            android:text="확인했어요" />


    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>