<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:paddingHorizontal="20dp"
    android:paddingVertical="16dp"
    android:layout_marginEnd="16dp"
    android:background="@drawable/gray_bg20">

    <TextView
        android:id="@+id/card_rank_tv"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_rank_circle"
        android:backgroundTint="@color/brand_100"
        android:text="A"
        android:gravity="center"
        android:textColor="@color/brand_800"
        android:textAppearance="@style/caption1_Semibold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/card_date_tv"
        app:layout_constraintBottom_toBottomOf="@id/card_address_tv"/>

    <TextView
        android:id="@+id/card_date_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0000년 00월 00일 탐색"
        android:textColor="@color/brand_100"
        android:textAppearance="@style/caption2_Regular"
        android:layout_marginStart="14dp"
        app:layout_constraintStart_toEndOf="@id/card_rank_tv"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/card_address_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="서울특별시 동작구\n상도로 50길"
        android:textAppearance="@style/caption1_Semibold"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@id/card_date_tv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_date_tv" />

    <TextView
        android:id="@+id/card_empty_img_tv"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/gray_bg16"
        android:gravity="center"
        android:text="아직 측정 데이터가 없어요"
        android:textColor="@color/white"
        android:textAppearance="@style/caption1_Median"
        android:backgroundTint="@color/gray_700"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/card_address_tv"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/card_img_rv"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/card_address_tv"/>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/image_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="card_empty_img_tv,card_img_rv" />

    <TextView
        android:id="@+id/card_measure_summary_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:paddingVertical="10dp"
        android:background="@drawable/black_badge"
        android:text="방 0개 방향 측정 • 채광 미측정"
        android:textColor="@color/white"
        android:textAppearance="@style/caption2_Semibold"
        app:layout_constraintTop_toBottomOf="@id/image_barrier"/>

</androidx.constraintlayout.widget.ConstraintLayout>