<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_marginTop="40dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <TextView
        android:id="@+id/after_noise_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="낮에는 {Char}, 밤에는 {Char}가 \n소음이 가장 낮아요."
        android:textAppearance="@style/body1_Semibold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/after_noise_des_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="각 수치를 터치하면 소음 예측 지수의 근거를 볼 수 있어요."
        android:textAppearance="@style/caption1_Median"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="@id/after_noise_tv"
        app:layout_constraintTop_toBottomOf="@id/after_noise_tv"/>

    <LinearLayout
        android:id="@+id/tab_day_night_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:background="@drawable/gray_bg20"
        android:backgroundTint="@color/gray_900"
        android:padding="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/after_noise_des_tv">

        <TextView
            android:id="@+id/after_day_tv"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:background="@drawable/gray_bg20"
            android:backgroundTint="@color/brand_600"
            android:gravity="center"
            android:layout_weight="1"
            android:text="낮"
            android:textColor="@color/white"
            android:textAppearance="@style/caption1_Semibold"/>

        <TextView
            android:id="@+id/after_night_tv"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/gray_bg20"
            android:backgroundTint="@color/gray_900"
            android:gravity="center"
            android:layout_weight="1"
            android:text="밤"
            android:textColor="@color/white"
            android:textAppearance="@style/caption1_Semibold"/>
    </LinearLayout>



    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/graph_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/gray_bg16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_day_night_container">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/before_graph_rv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:overScrollMode="never"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintWidth="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:listitem="@layout/item_graph_bar"/>

        <TextView
            android:id="@+id/graph_detail_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:padding="12dp"
            android:background="@drawable/gray_bg"
            android:text="그래프를 눌러 상세 정보를 확인하세요."
            android:textColor="@color/gray_300"
            android:textSize="12sp"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/before_graph_rv"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>