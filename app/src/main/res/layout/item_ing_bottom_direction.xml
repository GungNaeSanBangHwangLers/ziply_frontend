<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="52dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/gray_bg16"
    android:layout_marginBottom="16dp">

    <TextView
        android:id="@+id/num_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1차 측정"
        android:textAppearance="@style/body2_Regular"
        android:textColor="@color/gray_400"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/direction_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="{NN}°"
        android:textAppearance="@style/heading2_Median"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/num_tv"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:id="@+id/remove_iv"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/icon_close"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>



</androidx.constraintlayout.widget.ConstraintLayout>