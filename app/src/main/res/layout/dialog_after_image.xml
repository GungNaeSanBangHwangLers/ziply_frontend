<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/gray_bg"
    android:backgroundTint="@color/gray_800"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/dialog_rank_tv"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="20dp"
        android:background="@drawable/bg_rank_circle"
        android:backgroundTint="@color/brand_100"
        android:gravity="center"
        android:text="A"
        android:textAppearance="@style/caption1_Semibold"
        android:textColor="@color/brand_800"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/dialog_date_tv"
        app:layout_constraintBottom_toBottomOf="@id/dialog_address_tv"
        />

    <TextView
        android:id="@+id/dialog_date_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="20dp"
        android:text="0000년 00월 00일 탐색"
        android:textAppearance="@style/caption2_Regular"
        android:textColor="@color/brand_100"
        app:layout_constraintStart_toEndOf="@id/dialog_rank_tv"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/dialog_address_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="14dp"
        android:text="서울특별시 주소지"
        android:textAppearance="@style/caption1_Semibold"
        android:textColor="@color/white"
        app:layout_constraintEnd_toStartOf="@id/dialog_close_btn"
        app:layout_constraintStart_toStartOf="@id/dialog_date_tv"
        app:layout_constraintTop_toBottomOf="@id/dialog_date_tv" />

    <ImageView
        android:id="@+id/dialog_close_btn"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/icon_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/dialog_date_tv"
        app:layout_constraintBottom_toBottomOf="@id/dialog_address_tv"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/dialog_image_vp"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/dialog_address_tv" />

    <LinearLayout
        android:id="@+id/dialog_indicator_ll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dialog_image_vp" />

</androidx.constraintlayout.widget.ConstraintLayout>