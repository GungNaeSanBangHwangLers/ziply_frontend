<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:clickable="true"
    android:focusable="true"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <ImageView
    android:id="@+id/back_btn_iv"
    android:layout_width="24dp"
    android:layout_height="24dp"
    android:src="@drawable/back"
    android:layout_marginTop="76dp"
    android:layout_marginStart="20dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/schedule_title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="탐색할 집의 주소와\n탐색 일정을 입력해주세요"
        android:layout_marginTop="40dp"
        android:textAppearance="@style/heading2_Semibold"
        app:layout_constraintTop_toBottomOf="@id/back_btn_iv"
        app:layout_constraintStart_toStartOf="@id/back_btn_iv"/>

    <TextView
        android:id="@+id/schedule_des_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="정보를 2개 이상 입력하면\n자동으로 집에 대한 정보를 측정해드려요!"
        android:textAppearance="@style/body2_Median"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="@id/schedule_title_tv"
        app:layout_constraintTop_toBottomOf="@id/schedule_title_tv"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/schedule_addition_btn"
        style="@style/btn_L"
        android:backgroundTint="@color/gray_800"
        android:text="+주거지 주소 추가"
        android:textColor="@color/white"
        android:textAppearance="@style/body1_Semibold"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/schedule_des_tv"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/schedule_recycler_v"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:overScrollMode="never"
        app:layout_constraintVertical_bias="0.0"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/schedule_addition_btn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/address_next_btn_mb"
        tools:listitem="@layout/item_schedule"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/address_next_btn_mb"
        style="@style/btn_L"
        android:backgroundTint="@color/brand_700"
        android:text="다음으로"
        android:textColor="@color/white"
        android:layout_marginBottom="68dp"
        android:textAppearance="@style/body1_Semibold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>