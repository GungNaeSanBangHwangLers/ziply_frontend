            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="안전 점수는 {Char}가 \n가장 높아요."
            android:textAppearance="@style/body1_Semibold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/after_safety_des_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="학교에서 집 가는 길의 치안 인프라와 관련 뉴스를 기반으로\n알려드릴게요. 점수가 높을수록 좋아요."
            android:textAppearance="@style/caption1_Median"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="@id/after_safety_tv"
            app:layout_constraintTop_toBottomOf="@id/after_safety_tv"/>

