<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp">

        <TextView
            android:id="@+id/after_direction_title_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="건물의 방향정보를 \n알려줄게요"
            android:textAppearance="@style/body1_Semibold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/after_direction_des_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="건물은 방향에 따라 특성이 달라져요."
            android:textAppearance="@style/caption1_Median"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="@id/after_direction_title_tv"
            app:layout_constraintTop_toBottomOf="@id/after_direction_title_tv"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/direction_cards_rv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:clipToPadding="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/after_direction_des_tv"/>

        <TextView
            android:id="@+id/empty_state_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="측정된 데이터가 없어 \n결과를 준비하지 못했어요"
            android:gravity="center"
            android:textColor="@color/gray_400"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>