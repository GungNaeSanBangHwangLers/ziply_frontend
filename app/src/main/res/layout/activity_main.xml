<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    >

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_btn_container"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/main_hi_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginStart="20dp"
                android:text="안녕하세요 {User}님!"
                android:textAppearance="@style/heading2_Semibold"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/main_explore_count_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘 탐색 예정 주거가\n0개 있어요"
                android:textAppearance="@style/heading2_Semibold"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="@id/main_hi_tv"
                app:layout_constraintTop_toBottomOf="@id/main_hi_tv" />

            <TextView
                android:id="@+id/main_des_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="집 보러 가는 길, ZIPLY가 함께할게요"
                android:textAppearance="@style/body2_Median"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="@id/main_hi_tv"
                app:layout_constraintTop_toBottomOf="@id/main_explore_count_tv" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/main_explore_list_rv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:clipToPadding="false"
                android:paddingHorizontal="20dp"
                android:visibility="visible"
                app:layout_constraintTop_toBottomOf="@id/main_des_tv" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_empty_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/round_16dp_gray800"
                android:padding="20dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/main_des_tv">

                <TextView
                    android:id="@+id/empty_card_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="새로운 주거탐색을 시작해보세요"
                    android:textAppearance="@style/body1_Semibold"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/empty_card_des"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="집 보러 가는 길, ZIPLY가 함께할게요"
                    android:textAppearance="@style/caption1_Median"
                    android:textColor="@color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/empty_card_title" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/empty_card_add_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/btn_L"
                    android:backgroundTint="@color/brand_700"
                    android:text="주거탐색 추가하기"
                    android:textColor="@color/white"
                    android:textAppearance="@style/body1_Semibold"
                    app:layout_constraintTop_toBottomOf="@id/empty_card_des" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrier_cards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="main_explore_list_rv,layout_empty_card" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_checklist_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="40dp"
                android:background="@drawable/bg_bottom_sheet"
                android:backgroundTint="@color/gray_800"
                android:paddingHorizontal="26dp"
                android:paddingTop="40dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/barrier_cards">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/main_checklist_rv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_empty_checklist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="주거탐색을 등록하고\n일정을 한눈에 확인하세요"
                    android:textColor="@color/gray_500"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="40dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/bottom_btn_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gray_800"
        android:padding="20dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/main_plus_btn"
            style="@style/btn_L"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/brand_700"
            android:text="주거탐색 추가하기"
            android:textColor="@color/white" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/error_main_ll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="새로고침을 시도해주세요"
            android:textColor="@color/brand_400"
            android:textStyle="bold"
            android:textSize="18sp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="데이터를 불러오는데 실패했어요"
            android:textColor="@color/gray_400" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/error_main_reload_bt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/brand_700"
            android:text="새로고침"
            android:textColor="@color/white"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/brand_600"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/main_frm"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>