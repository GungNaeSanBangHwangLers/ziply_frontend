<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/view_main_cv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">
        <TextView
            android:id="@+id/main_hi_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="안녕하세요 김종하님!"
            android:textAppearance="@style/heading2_Semibold"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="106dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            />
        <TextView
            android:id="@+id/main_des_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="집 보러 가는 길, ZIPLY가 함께할게요"
            android:textAppearance="@style/body2_Median"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/main_hi_tv"
            app:layout_constraintStart_toStartOf="@id/main_hi_tv"/>
        
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/main_explor_list_rl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginStart="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/main_des_tv"/>

        <me.relex.circleindicator.CircleIndicator2
            android:id="@+id/main_card_indicator_ci"
            android:layout_width="match_parent"
            android:layout_height="4dp"

            app:ci_drawable="@drawable/indicator_selected"
            app:ci_drawable_unselected="@drawable/indicator_unselected"

            app:ci_width="4dp"
            app:ci_height="4dp"
            app:ci_margin="2dp"
            android:layout_marginTop="28dp"
            
            app:layout_constraintTop_toBottomOf="@id/main_explor_list_rl"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/main_plus_btn"
            style="@style/btn_L"
            android:backgroundTint="@color/brand_700"
            android:text="주거탐색 추가하기"
            android:textColor="@color/white"
            android:layout_marginTop="28dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/main_card_indicator_ci"
            />
    </androidx.constraintlayout.widget.ConstraintLayout>
    
    <LinearLayout
        android:id="@+id/empty_main_ll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/empty_main_hi_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="안녕하세요 {User}님!"
            android:textAppearance="@style/heading2_Semibold"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/empty_main_des_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="집 보러 가는 길, ZIPLY가 함께할게요"
            android:textAppearance="@style/body2_Median"
            />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/empty_main_plus_btn"
            style="@style/btn_L"
            android:backgroundTint="@color/brand_700"
            android:text="주거탐색 추가하기"
            android:textColor="@color/white"
            android:layout_marginTop="20dp"
            />


    </LinearLayout>
    
    <LinearLayout
        android:id="@+id/error_main_ll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <TextView
            android:id="@+id/error_main_des_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="새로고침을 시도해주세요"
            android:textAppearance="@style/heading2_Semibold"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/error_main_des2_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="데이터를 불러오는데 실패했어요"
            android:textAppearance="@style/body2_Median"
            android:textStyle="bold"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/error_main_reload_bt"
            style="@style/btn_S"
            android:backgroundTint="@color/brand_700"
            android:text="새로고침"
            android:textColor="@color/white"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        android:indeterminateTint="@color/brand_900"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <FrameLayout
        android:id="@+id/main_frm"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>